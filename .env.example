# ── App kanonik URL ──────────────────────────────────────────────────────────
# Mahalliy dev uchun:   http://localhost:3000
# Vercel Production da: https://jetblog.app   ← o'zgaruvchini shu qiymatga o'rnating!
# Bu o'zgaruvchi auth redirect, sitemap, og:url va telegram notify uchun ishlatiladi.
NEXT_PUBLIC_DOMAIN='http://localhost:3000'
NEXT_PUBLIC_ENVIRONMENT='development'

# Supabase (Replace with your actual Supabase API keys)
NEXT_PUBLIC_SUPABASE_URL='https://your-project.supabase.co'
NEXT_PUBLIC_SUPABASE_ANON_KEY='your-anon-key'
SUPABASE_SERVICE_ROLE_KEY='your-service-role-key'

# Artificial Intelligence (AI) API Keys
ANTHROPIC_API_KEY='sk-ant-api03-...' # For Claude 3.5 Sonnet
OPENAI_API_KEY='sk-proj-...'         # For DALL-E 3 Featured Images

# SEO and Search Analytics APIs
DATAFORSEO_LOGIN='your_dataforseo_login'
DATAFORSEO_PASSWORD='your_dataforseo_password'

# Telegram Channel Integration
TELEGRAM_BOT_TOKEN='1234567890:AAH...'

# Security & Cron Automation
CRON_SECRET='super_secret_cron_token_123'
SUPABASE_VAULT_KEY='your_vault_encryption_key_for_wp_passwords'

# Upstash QStash (Autopilot navbati — ixtiyoriy, yo'q bo'lsa HTTP fallback)
# https://console.upstash.com → QStash
QSTASH_TOKEN='qstash_token_here'
QSTASH_CURRENT_SIGNING_KEY='sig_current_here'
QSTASH_NEXT_SIGNING_KEY='sig_next_here'

# Rate Limiting (Upstash Redis)
# https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL='https://your-redis.upstash.io'
UPSTASH_REDIS_REST_TOKEN='your-upstash-token'

# Error Monitoring (Sentry)
# https://sentry.io → Settings → Projects → DSN
SENTRY_DSN='https://your-key@sentry.io/your-project-id'
NEXT_PUBLIC_SENTRY_DSN='https://your-key@sentry.io/your-project-id'
SENTRY_ORG='your-sentry-org-slug'
SENTRY_PROJECT='your-sentry-project-slug'
SENTRY_AUTH_TOKEN='your-sentry-auth-token'  # Source map upload uchun

# ── PayPal Subscriptions ────────────────────────────────────────────────────
# Vercel: bu barcha o'zgaruvchilarni Production va Preview'ga qo'shing.
# Sandbox va Live credentials'ni PayPal Developer dashboard'dan oling.
PAYPAL_MODE='sandbox'                     # 'sandbox' yoki 'live'
PAYPAL_CLIENT_ID_SANDBOX=''
PAYPAL_SECRET_SANDBOX=''
PAYPAL_CLIENT_ID_LIVE=''
PAYPAL_SECRET_LIVE=''
PAYPAL_WEBHOOK_ID_SANDBOX=''              # Webhook create qilingandan keyin oling
PAYPAL_WEBHOOK_ID_LIVE=''
PAYPAL_PLAN_STARTER_SANDBOX=''            # PayPal dashboard'da yaratilgan plan_id
PAYPAL_PLAN_PRO_SANDBOX=''
PAYPAL_PLAN_STARTER_LIVE=''
PAYPAL_PLAN_PRO_LIVE=''
# Frontda ishlatiladigan client_id — mode'ga mos Sandbox yoki Live client id
NEXT_PUBLIC_PAYPAL_CLIENT_ID=''
